# Database
DATABASE_URL="postgresql://user:password@localhost:5432/dbname"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-here"

# OAuth Providers
# Google OAuth - Get credentials from https://console.cloud.google.com/
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# GitHub OAuth - Get credentials from https://github.com/settings/developers
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# Apple OAuth - Get credentials from https://developer.apple.com/
APPLE_CLIENT_ID="your-apple-client-id"
APPLE_CLIENT_SECRET="your-apple-client-secret"

# OpenAI (for AI features)
OPENAI_API_KEY="your-openai-api-key"

# ─── AI Providers ───

# Google Gemini API — MEDIUM tasks (fast, creative)
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-2.5-flash"

# Anthropic Claude API — HIGH_QUALITY tasks (reasoning, code)
ANTHROPIC_API_KEY="your-anthropic-api-key"

# Ollama — LOCAL fallback (simple tasks)
OLLAMA_ENABLED="true"
OLLAMA_MODEL="llama3.1"
OLLAMA_HOST="http://localhost:11434"

# LM Studio — LOCAL fallback (simple tasks)
LM_STUDIO_BASE_URL="http://127.0.0.1:1234/v1"
LM_STUDIO_MODEL="local-model"

# ─── AI Routing ───

# Routing mode: local-first | cloud-first | balanced | quality-first | cheap
# "balanced" uses smart task-to-provider mapping based on task complexity
AI_ROUTING_MODE="balanced"

# Enable/disable provider categories
ENABLE_LOCAL_MODELS="true"
ENABLE_CLOUD_MODELS="true"
