// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// AUTH & USER MANAGEMENT
// ============================================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String    // hashed with bcrypt
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  projects       Project[]
  lessonProgress LessonProgress[]
  quizAttempts   QuizAttempt[]

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================================
// PROJECT MANAGEMENT
// ============================================================================

enum ProjectState {
  IDEA
  STRUCTURED
  VALIDATED
  BUILD_READY
  MVP_GENERATED
  BLOCKED
}

model Project {
  id          String       @id @default(cuid())
  name        String
  description String?      @db.Text
  state       ProjectState @default(IDEA)
  userId      String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user               User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions           ProjectVersion[]
  wizardAnswers      WizardAnswer[]
  viabilityScores    ViabilityScore[]
  evaluationFindings EvaluationFinding[]
  risks              RiskMatrix[]
  artifacts          GeneratedArtifact[]
  templateMapping    TemplateMapping?
  buildArtifacts     BuildArtifact[]
  course             Course?

  @@index([userId])
  @@index([state])
  @@index([createdAt])
}

// ============================================================================
// WIZARD INPUTS
// ============================================================================

model WizardAnswer {
  id        String   @id @default(cuid())
  projectId String
  step      Int      // 1-10
  key       String   // field identifier (e.g., "targetAudience", "problemStatement")
  value     String?  @db.Text // JSON for complex values
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, step, key])
  @@index([projectId])
}

// ============================================================================
// VERSIONING
// ============================================================================

model ProjectVersion {
  id                     String       @id @default(cuid())
  projectId              String
  versionNumber          Int          // Auto-increment per project
  description            String?      @db.Text
  projectState           ProjectState
  wizardAnswersSnapshot  Json?        // Snapshot of all wizard answers
  viabilityScoreSnapshot Json?        // Snapshot of latest score
  findingsSnapshot       Json?        // Snapshot of findings
  risksSnapshot          Json?        // Snapshot of risks
  artifactsSnapshot      Json?        // Snapshot of artifact references/content
  buildArtifactId        String?      // Reference to build if exists
  createdAt              DateTime     @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, versionNumber])
  @@index([projectId])
  @@index([createdAt])
}


// ============================================================================
// EVALUATION & SCORING
// ============================================================================

model ViabilityScore {
  id                String   @id @default(cuid())
  projectId         String
  marketScore       Float    // 0-25
  productScore      Float    // 0-25
  financialScore    Float    // 0-25
  executionScore    Float    // 0-25
  totalScore        Float    // 0-100
  breakdownReasons  Json     // Array of {category, reason, points, penalty}
  criticalFlags     Json     // Array of critical issue codes
  computedAt        DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([computedAt])
}

enum FindingSeverity {
  INFO
  WARNING
  CRITICAL
}

model EvaluationFinding {
  id            String           @id @default(cuid())
  projectId     String
  severity      FindingSeverity
  code          String           // e.g., "MONETIZATION_MISMATCH"
  message       String           @db.Text
  relatedFields Json?            // Array of wizard keys or artifact IDs
  penaltyPoints Float            @default(0)
  blocksBuild   Boolean          @default(false)
  createdAt     DateTime         @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([severity])
  @@index([blocksBuild])
}

// ============================================================================
// RISK MANAGEMENT
// ============================================================================

enum RiskCategory {
  MARKET
  PRODUCT
  FINANCIAL
  TECHNICAL
  LEGAL
  EXECUTION
}

model RiskMatrix {
  id          String       @id @default(cuid())
  projectId   String
  category    RiskCategory
  title       String
  description String       @db.Text
  impact      Int          // 1-5
  probability Int          // 1-5
  riskScore   Int          // impact * probability (1-25)
  isCritical  Boolean      @default(false) // riskScore >= 16
  mitigation  String?      @db.Text
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([isCritical])
  @@index([riskScore])
}

// ============================================================================
// ARTIFACTS
// ============================================================================

enum ArtifactType {
  BUSINESS_MODEL_CANVAS
  PRODUCT_REQUIREMENTS
  TECHNICAL_ARCHITECTURE
  USER_STORIES
  RISK_ASSESSMENT
  GO_TO_MARKET
}

model GeneratedArtifact {
  id        String       @id @default(cuid())
  projectId String
  type      ArtifactType
  title     String
  content   String       @db.Text // Markdown or JSON
  metadata  Json?        // Additional structured data
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, type])
  @@index([projectId])
}

// ============================================================================
// TEMPLATE MAPPING
// ============================================================================

enum TemplateType {
  SAAS_BASIC
  MARKETPLACE_MINI
  ECOMMERCE_MINI
  LANDING_BLOG
}

model TemplateMapping {
  id                  String       @id @default(cuid())
  projectId           String       @unique
  recommendedTemplate TemplateType
  confidence          Float        // 0-1
  reasoning           String       @db.Text
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}


// ============================================================================
// BUILD ENGINE
// ============================================================================

enum BuildStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

model BuildArtifact {
  id                  String       @id @default(cuid())
  projectId           String
  templateType        TemplateType
  status              BuildStatus  @default(PENDING)
  zipPath             String?      // Path to generated ZIP file
  buildLog            String?      @db.Text
  errorMessage        String?      @db.Text
  parameters          Json         // Build parameters (app name, branding, etc.)
  qualityChecksPassed Boolean      @default(false)
  createdAt           DateTime     @default(now())
  completedAt         DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
}

// ============================================================================
// COURSE SYSTEM (Learn 2.0)
// ============================================================================

model Course {
  id          String   @id @default(cuid())
  projectId   String   @unique
  title       String
  description String   @db.Text
  metadata    Json     // Course-level metadata (tech stack, business model, etc.)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  levels  CourseLevel[]

  @@index([projectId])
}

model CourseLevel {
  id          String   @id @default(cuid())
  courseId    String
  levelNumber Int      // 1-6
  title       String
  description String   @db.Text
  objectives  Json     // Array of learning objectives
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]
  quizzes Quiz[]

  @@unique([courseId, levelNumber])
  @@index([courseId])
}

model Lesson {
  id          String   @id @default(cuid())
  levelId     String
  lessonNumber Int     // Order within level
  title       String
  description String   @db.Text
  content     Json     // Array of content blocks
  estimatedMinutes Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  level    CourseLevel      @relation(fields: [levelId], references: [id], onDelete: Cascade)
  progress LessonProgress[]

  @@unique([levelId, lessonNumber])
  @@index([levelId])
}

model LessonProgress {
  id          String    @id @default(cuid())
  userId      String
  lessonId    String
  completed   Boolean   @default(false)
  timeSpent   Int?      // Minutes spent on lesson
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
}

model Quiz {
  id          String   @id @default(cuid())
  levelId     String
  title       String
  description String   @db.Text
  questions   Json     // Array of quiz questions with options
  passingScore Int     @default(70) // Percentage required to pass
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  level    CourseLevel   @relation(fields: [levelId], references: [id], onDelete: Cascade)
  attempts QuizAttempt[]

  @@index([levelId])
}

model QuizAttempt {
  id          String   @id @default(cuid())
  userId      String
  quizId      String
  answers     Json     // Array of user answers
  score       Int      // Percentage score
  passed      Boolean
  completedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([quizId])
  @@index([completedAt])
}

model GlossaryTerm {
  id         String   @id @default(cuid())
  courseId   String
  term       String
  definition String   @db.Text
  category   String   // business, technical, legal, marketing
  relatedTerms Json?  // Array of related term IDs
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([courseId])
  @@index([category])
}

// ============================================================================
// OPPORTUNITIES & MARKET INTELLIGENCE
// ============================================================================

model Opportunity {
  id                     String   @id @default(cuid())
  userId                 String
  title                  String
  hook                   String   @db.Text
  category               String
  sector                 String
  problemStatement       String   @db.Text
  targetAudience         String   @db.Text
  buyerPersona           String?  @db.Text
  painLevel              Int?     // 1-10
  solutionOverview       String   @db.Text
  mvpScope               String?  @db.Text
  coreFeatures           Json     // Array of strings
  demandScore            Int      // 0-100
  demandSignals          Json     // Array of {source, signal, strength}
  competitionScore       Int      // 0-100
  competitionSnapshot    String?  @db.Text
  differentiationAngles  Json?    // Array of strings
  pricingSuggestions     String?  @db.Text
  pricingRationale       String?  @db.Text
  monetizationType       String?  // subscription, one-time, freemium, usage-based, marketplace
  timingSignals          Json?    // Array of strings
  gtmChannels            Json?    // Array of strings
  risks                  Json?    // Array of strings
  mitigations            Json?    // Array of strings
  executionDifficulty    Int?     // 1-5
  executionReasons       Json?    // Array of strings
  timeToMVP              String?
  requiredSkills         Json?    // Array of strings
  recommendedStack       Json?    // Array of strings
  acceptanceCriteria     Json?    // Array of strings
  nextSteps              Json?    // Array of strings
  viabilityScore         Float?   // Computed score
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  projectLinks OpportunityProjectLink[]

  @@index([userId])
  @@index([sector])
  @@index([viabilityScore])
  @@index([createdAt])
}

model OpportunityProjectLink {
  id            String   @id @default(cuid())
  opportunityId String
  projectId     String
  wizardSeed    Json?    // Pre-filled wizard data
  createdAt     DateTime @default(now())

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@unique([opportunityId, projectId])
  @@index([projectId])
}

model MarketGap {
  id                  String   @id @default(cuid())
  userId              String
  title               String
  sector              String
  underservedSegment  String   @db.Text
  competitionLevel    String   // low, medium, high
  gapDescription      String   @db.Text
  evidence            Json     // Array of {signal, strength, source}
  wedgeStrategy       String   @db.Text
  estimatedMarketSize String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  variants      MarketGapVariant[]
  projectLinks  MarketGapProjectLink[]

  @@index([userId])
  @@index([sector])
  @@index([competitionLevel])
  @@index([createdAt])
}

model MarketGapVariant {
  id                String   @id @default(cuid())
  marketGapId       String
  approach          String   // Premium, Volume, Niche
  title             String
  targetSubSegment  String   @db.Text
  differentiator    String   @db.Text
  fullDossier       Json     // Complete BusinessIntelligenceDossier
  createdAt         DateTime @default(now())

  marketGap     MarketGap              @relation(fields: [marketGapId], references: [id], onDelete: Cascade)
  projectLinks  MarketGapProjectLink[]

  @@index([marketGapId])
}

model MarketGapProjectLink {
  id                  String   @id @default(cuid())
  projectId           String
  marketGapId         String
  marketGapVariantId  String
  wizardSeed          Json?    // Pre-filled wizard data
  createdAt           DateTime @default(now())

  marketGap MarketGap          @relation(fields: [marketGapId], references: [id], onDelete: Cascade)
  variant   MarketGapVariant   @relation(fields: [marketGapVariantId], references: [id], onDelete: Cascade)

  @@unique([projectId, marketGapVariantId])
  @@index([projectId])
  @@index([marketGapId])
}

// ============================================================================
// AI ASSISTANT
// ============================================================================

model Conversation {
  id        String   @id @default(cuid())
  userId    String
  title     String   @default("New Conversation")
  projectId String?  // Optional project context
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages Message[]

  @@index([userId])
  @@index([projectId])
  @@index([updatedAt])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // user, assistant, system
  content        String   @db.Text
  metadata       Json?    // Additional context (project data, etc.)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
}

// ============================================================================
// LEARN TASKS (for progress tracking)
// ============================================================================

model LearnTask {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  description String?  @db.Text
  completed   Boolean  @default(false)
  order       Int      // Display order
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
  @@index([completed])
}
