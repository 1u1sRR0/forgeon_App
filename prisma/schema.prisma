generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  User              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model BuildArtifact {
  id                  String       @id
  projectId           String
  templateType        TemplateType
  status              BuildStatus  @default(PENDING)
  zipPath             String?
  buildLog            String?
  errorMessage        String?
  parameters          Json
  qualityChecksPassed Boolean      @default(false)
  createdAt           DateTime     @default(now())
  completedAt         DateTime?
  Project             Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
}

model Conversation {
  id        String    @id
  userId    String
  title     String    @default("New Conversation")
  projectId String?
  createdAt DateTime  @default(now())
  updatedAt DateTime
  Message   Message[]

  @@index([projectId])
  @@index([updatedAt])
  @@index([userId])
}

model Course {
  id          String        @id
  projectId   String        @unique
  title       String
  description String
  metadata    Json
  createdAt   DateTime      @default(now())
  updatedAt   DateTime
  Project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  CourseLevel CourseLevel[]

  @@index([projectId])
}

model CourseLevel {
  id          String   @id
  courseId    String
  levelNumber Int
  title       String
  description String
  objectives  Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  Course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  Lesson      Lesson[]
  Quiz        Quiz[]

  @@unique([courseId, levelNumber])
  @@index([courseId])
}

model EvaluationFinding {
  id            String          @id
  projectId     String
  severity      FindingSeverity
  code          String
  message       String
  relatedFields Json?
  penaltyPoints Float           @default(0)
  blocksBuild   Boolean         @default(false)
  createdAt     DateTime        @default(now())
  Project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([blocksBuild])
  @@index([projectId])
  @@index([severity])
}

model GeneratedArtifact {
  id        String       @id
  projectId String
  type      ArtifactType
  title     String
  content   String
  metadata  Json?
  createdAt DateTime     @default(now())
  updatedAt DateTime
  Project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, type])
  @@index([projectId])
}

model GlossaryTerm {
  id           String   @id
  courseId     String
  term         String
  definition   String
  category     String
  relatedTerms Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime

  @@index([category])
  @@index([courseId])
}

model LearnTask {
  id          String   @id
  projectId   String
  title       String
  description String?
  completed   Boolean  @default(false)
  order       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime

  @@index([completed])
  @@index([projectId])
}

model Lesson {
  id               String           @id
  levelId          String
  lessonNumber     Int
  title            String
  description      String
  content          Json
  estimatedMinutes Int
  createdAt        DateTime         @default(now())
  updatedAt        DateTime
  CourseLevel      CourseLevel      @relation(fields: [levelId], references: [id], onDelete: Cascade)
  LessonProgress   LessonProgress[]

  @@unique([levelId, lessonNumber])
  @@index([levelId])
}

model LessonProgress {
  id          String    @id
  userId      String
  lessonId    String
  completed   Boolean   @default(false)
  timeSpent   Int?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  Lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  User        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([lessonId])
  @@index([userId])
}

model MarketGap {
  id                   String                 @id
  userId               String
  title                String
  sector               String
  underservedSegment   String
  competitionLevel     String
  gapDescription       String
  evidence             Json
  wedgeStrategy        String
  estimatedMarketSize  String
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  MarketGapProjectLink MarketGapProjectLink[]
  MarketGapVariant     MarketGapVariant[]

  @@index([competitionLevel])
  @@index([createdAt])
  @@index([sector])
  @@index([userId])
}

model MarketGapProjectLink {
  id                 String           @id
  projectId          String
  marketGapId        String
  marketGapVariantId String
  wizardSeed         Json?
  createdAt          DateTime         @default(now())
  MarketGap          MarketGap        @relation(fields: [marketGapId], references: [id], onDelete: Cascade)
  MarketGapVariant   MarketGapVariant @relation(fields: [marketGapVariantId], references: [id], onDelete: Cascade)

  @@unique([projectId, marketGapVariantId])
  @@index([marketGapId])
  @@index([projectId])
}

model MarketGapVariant {
  id                   String                 @id
  marketGapId          String
  approach             String
  title                String
  targetSubSegment     String
  differentiator       String
  fullDossier          Json
  createdAt            DateTime               @default(now())
  MarketGapProjectLink MarketGapProjectLink[]
  MarketGap            MarketGap              @relation(fields: [marketGapId], references: [id], onDelete: Cascade)

  @@index([marketGapId])
}

model Message {
  id             String       @id
  conversationId String
  role           String
  content        String
  metadata       Json?
  createdAt      DateTime     @default(now())
  Conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
}

model Opportunity {
  id                     String                   @id
  userId                 String
  title                  String
  hook                   String
  category               String
  sector                 String
  problemStatement       String
  targetAudience         String
  buyerPersona           String?
  painLevel              Int?
  solutionOverview       String
  mvpScope               String?
  coreFeatures           Json
  demandScore            Int
  demandSignals          Json
  competitionScore       Int
  competitionSnapshot    String?
  differentiationAngles  Json?
  pricingSuggestions     String?
  pricingRationale       String?
  monetizationType       String?
  timingSignals          Json?
  gtmChannels            Json?
  risks                  Json?
  mitigations            Json?
  executionDifficulty    Int?
  executionReasons       Json?
  timeToMVP              String?
  requiredSkills         Json?
  recommendedStack       Json?
  acceptanceCriteria     Json?
  nextSteps              Json?
  viabilityScore         Float?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime
  OpportunityProjectLink OpportunityProjectLink[]

  @@index([createdAt])
  @@index([sector])
  @@index([userId])
  @@index([viabilityScore])
}

model OpportunityProjectLink {
  id            String      @id
  opportunityId String
  projectId     String
  wizardSeed    Json?
  createdAt     DateTime    @default(now())
  Opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@unique([opportunityId, projectId])
  @@index([projectId])
}

model Project {
  id                String              @id
  name              String
  description       String?
  state             ProjectState        @default(IDEA)
  userId            String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  BuildArtifact       BuildArtifact[]
  Course              Course?
  EvaluationFinding   EvaluationFinding[]
  GeneratedArtifact   GeneratedArtifact[]
  User                User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  ProjectVersion      ProjectVersion[]
  ProjectResearchItem ProjectResearchItem[]
  RiskMatrix          RiskMatrix[]
  TemplateMapping     TemplateMapping?
  ViabilityScore      ViabilityScore[]
  WizardAnswer        WizardAnswer[]

  @@index([createdAt])
  @@index([state])
  @@index([userId])
}

model ProjectVersion {
  id                     String       @id
  projectId              String
  versionNumber          Int
  description            String?
  projectState           ProjectState
  wizardAnswersSnapshot  Json?
  viabilityScoreSnapshot Json?
  findingsSnapshot       Json?
  risksSnapshot          Json?
  artifactsSnapshot      Json?
  buildArtifactId        String?
  createdAt              DateTime     @default(now())
  Project                Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, versionNumber])
  @@index([createdAt])
  @@index([projectId])
}

model Quiz {
  id           String        @id
  levelId      String
  title        String
  description  String
  questions    Json
  passingScore Int           @default(70)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime
  CourseLevel  CourseLevel   @relation(fields: [levelId], references: [id], onDelete: Cascade)
  QuizAttempt  QuizAttempt[]

  @@index([levelId])
}

model QuizAttempt {
  id          String   @id
  userId      String
  quizId      String
  answers     Json
  score       Int
  passed      Boolean
  completedAt DateTime @default(now())
  Quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  User        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([completedAt])
  @@index([quizId])
  @@index([userId])
}

model RiskMatrix {
  id          String       @id
  projectId   String
  category    RiskCategory
  title       String
  description String
  impact      Int
  probability Int
  riskScore   Int
  isCritical  Boolean      @default(false)
  mitigation  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime
  Project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([isCritical])
  @@index([projectId])
  @@index([riskScore])
}

model Session {
  id           String   @id
  sessionToken String   @unique
  userId       String
  expires      DateTime
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TemplateMapping {
  id                  String       @id
  projectId           String       @unique
  recommendedTemplate TemplateType
  confidence          Float
  reasoning           String
  createdAt           DateTime     @default(now())
  updatedAt           DateTime
  Project             Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model User {
  id             String           @id
  email          String           @unique
  name           String?
  password       String
  emailVerified  DateTime?
  image          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  Account        Account[]
  LessonProgress LessonProgress[]
  Project        Project[]
  QuizAttempt    QuizAttempt[]
  Session        Session[]

  @@index([email])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ViabilityScore {
  id               String   @id
  projectId        String
  marketScore      Float
  productScore     Float
  financialScore   Float
  executionScore   Float
  totalScore       Float
  breakdownReasons Json
  criticalFlags    Json
  computedAt       DateTime @default(now())
  Project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([computedAt])
  @@index([projectId])
}

model WizardAnswer {
  id        String   @id
  projectId String
  step      Int
  key       String
  value     String?
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime
  Project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, step, key])
  @@index([projectId])
}

enum ArtifactType {
  BUSINESS_MODEL_CANVAS
  PRODUCT_REQUIREMENTS
  TECHNICAL_ARCHITECTURE
  USER_STORIES
  RISK_ASSESSMENT
  GO_TO_MARKET
}

enum BuildStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum FindingSeverity {
  INFO
  WARNING
  CRITICAL
}

enum ProjectState {
  IDEA
  STRUCTURED
  VALIDATED
  BUILD_READY
  MVP_GENERATED
  BLOCKED
}

enum RiskCategory {
  MARKET
  PRODUCT
  FINANCIAL
  TECHNICAL
  LEGAL
  EXECUTION
}

enum TemplateType {
  SAAS_BASIC
  MARKETPLACE_MINI
  ECOMMERCE_MINI
  LANDING_BLOG
}

enum MarketIntelType {
  TREND
  SECTOR_INSIGHT
  STARTUP_DATA
  DEMAND_INDICATOR
}

model MarketIntelItem {
  id                  String                @id
  userId              String
  title               String
  type                MarketIntelType
  summary             String
  sector              String
  confidence          Int
  signals             Json
  content             Json
  region              String?
  timeframe           String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime
  ProjectResearchItem ProjectResearchItem[]

  @@index([userId])
  @@index([type])
  @@index([sector])
  @@index([confidence])
}

model ProjectResearchItem {
  id              String          @id
  projectId       String
  marketIntelId   String
  notes           String?
  createdAt       DateTime        @default(now())
  Project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  MarketIntelItem MarketIntelItem @relation(fields: [marketIntelId], references: [id], onDelete: Cascade)

  @@unique([projectId, marketIntelId])
  @@index([projectId])
  @@index([marketIntelId])
}
