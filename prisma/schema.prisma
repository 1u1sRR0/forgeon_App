// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// AUTH & USER MANAGEMENT
// ============================================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String    // hashed with bcrypt
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  projects Project[]

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================================
// PROJECT MANAGEMENT
// ============================================================================

enum ProjectState {
  IDEA
  STRUCTURED
  VALIDATED
  BUILD_READY
  MVP_GENERATED
  BLOCKED
}

model Project {
  id          String       @id @default(cuid())
  name        String
  description String?      @db.Text
  state       ProjectState @default(IDEA)
  userId      String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user               User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions           ProjectVersion[]
  wizardAnswers      WizardAnswer[]
  viabilityScores    ViabilityScore[]
  evaluationFindings EvaluationFinding[]
  risks              RiskMatrix[]
  artifacts          GeneratedArtifact[]
  templateMapping    TemplateMapping?
  buildArtifacts     BuildArtifact[]

  @@index([userId])
  @@index([state])
  @@index([createdAt])
}

// ============================================================================
// WIZARD INPUTS
// ============================================================================

model WizardAnswer {
  id        String   @id @default(cuid())
  projectId String
  step      Int      // 1-10
  key       String   // field identifier (e.g., "targetAudience", "problemStatement")
  value     String?  @db.Text // JSON for complex values
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, step, key])
  @@index([projectId])
}

// ============================================================================
// VERSIONING
// ============================================================================

model ProjectVersion {
  id                     String       @id @default(cuid())
  projectId              String
  versionNumber          Int          // Auto-increment per project
  description            String?      @db.Text
  projectState           ProjectState
  wizardAnswersSnapshot  Json?        // Snapshot of all wizard answers
  viabilityScoreSnapshot Json?        // Snapshot of latest score
  findingsSnapshot       Json?        // Snapshot of findings
  risksSnapshot          Json?        // Snapshot of risks
  artifactsSnapshot      Json?        // Snapshot of artifact references/content
  buildArtifactId        String?      // Reference to build if exists
  createdAt              DateTime     @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, versionNumber])
  @@index([projectId])
  @@index([createdAt])
}


// ============================================================================
// EVALUATION & SCORING
// ============================================================================

model ViabilityScore {
  id                String   @id @default(cuid())
  projectId         String
  marketScore       Float    // 0-25
  productScore      Float    // 0-25
  financialScore    Float    // 0-25
  executionScore    Float    // 0-25
  totalScore        Float    // 0-100
  breakdownReasons  Json     // Array of {category, reason, points, penalty}
  criticalFlags     Json     // Array of critical issue codes
  computedAt        DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([computedAt])
}

enum FindingSeverity {
  INFO
  WARNING
  CRITICAL
}

model EvaluationFinding {
  id            String           @id @default(cuid())
  projectId     String
  severity      FindingSeverity
  code          String           // e.g., "MONETIZATION_MISMATCH"
  message       String           @db.Text
  relatedFields Json?            // Array of wizard keys or artifact IDs
  penaltyPoints Float            @default(0)
  blocksBuild   Boolean          @default(false)
  createdAt     DateTime         @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([severity])
  @@index([blocksBuild])
}

// ============================================================================
// RISK MANAGEMENT
// ============================================================================

enum RiskCategory {
  MARKET
  PRODUCT
  FINANCIAL
  TECHNICAL
  LEGAL
  EXECUTION
}

model RiskMatrix {
  id          String       @id @default(cuid())
  projectId   String
  category    RiskCategory
  title       String
  description String       @db.Text
  impact      Int          // 1-5
  probability Int          // 1-5
  riskScore   Int          // impact * probability (1-25)
  isCritical  Boolean      @default(false) // riskScore >= 16
  mitigation  String?      @db.Text
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([isCritical])
  @@index([riskScore])
}

// ============================================================================
// ARTIFACTS
// ============================================================================

enum ArtifactType {
  BUSINESS_MODEL_CANVAS
  PRODUCT_REQUIREMENTS
  TECHNICAL_ARCHITECTURE
  USER_STORIES
  RISK_ASSESSMENT
  GO_TO_MARKET
}

model GeneratedArtifact {
  id        String       @id @default(cuid())
  projectId String
  type      ArtifactType
  title     String
  content   String       @db.Text // Markdown or JSON
  metadata  Json?        // Additional structured data
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, type])
  @@index([projectId])
}

// ============================================================================
// TEMPLATE MAPPING
// ============================================================================

enum TemplateType {
  SAAS_BASIC
  MARKETPLACE_MINI
  ECOMMERCE_MINI
  LANDING_BLOG
}

model TemplateMapping {
  id                  String       @id @default(cuid())
  projectId           String       @unique
  recommendedTemplate TemplateType
  confidence          Float        // 0-1
  reasoning           String       @db.Text
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}


// ============================================================================
// BUILD ENGINE
// ============================================================================

enum BuildStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

model BuildArtifact {
  id                  String       @id @default(cuid())
  projectId           String
  templateType        TemplateType
  status              BuildStatus  @default(PENDING)
  zipPath             String?      // Path to generated ZIP file
  buildLog            String?      @db.Text
  errorMessage        String?      @db.Text
  parameters          Json         // Build parameters (app name, branding, etc.)
  qualityChecksPassed Boolean      @default(false)
  createdAt           DateTime     @default(now())
  completedAt         DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
}
